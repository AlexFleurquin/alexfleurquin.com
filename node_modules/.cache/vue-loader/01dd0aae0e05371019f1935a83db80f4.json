{"remainingRequest":"/Users/alexfleurquin/Desktop/Projets/AF/Cruips/appy-vue/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/alexfleurquin/Desktop/Projets/AF/Cruips/appy-vue/src/partials/TestimonialsCarousel.vue?vue&type=script&lang=js&","dependencies":[{"path":"/Users/alexfleurquin/Desktop/Projets/AF/Cruips/appy-vue/src/partials/TestimonialsCarousel.vue","mtime":1608282377000},{"path":"/Users/alexfleurquin/Desktop/Projets/AF/Cruips/appy-vue/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/alexfleurquin/Desktop/Projets/AF/Cruips/appy-vue/node_modules/babel-loader/lib/index.js","mtime":315532800000},{"path":"/Users/alexfleurquin/Desktop/Projets/AF/Cruips/appy-vue/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/alexfleurquin/Desktop/Projets/AF/Cruips/appy-vue/node_modules/vue-loader/lib/index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["TestimonialsCarousel.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAyEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"TestimonialsCarousel.vue","sourceRoot":"src/partials","sourcesContent":["<template>\n  <section>\n    <div class=\"max-w-6xl mx-auto px-4 sm:px-6\">\n      <div class=\"pb-12 md:pb-20\">\n\n        <!-- Carousel area -->\n        <div class=\"max-w-5xl mx-auto\">\n\n          <!-- Carousel -->\n          <div class=\"relative\" data-aos=\"fade-down\">\n\n            <!-- Testimonials -->\n            <transition-group\n              tag=\"div\"\n              class=\"relative flex items-start z-10 transition-all duration-300 ease-in-out\"\n              enter-active-class=\"transition ease-in-out duration-700 transform order-first\"\n              enter-class=\"opacity-0 -translate-y-8\"\n              enter-to-class=\"opacity-100 translate-y-0\"\n              leave-active-class=\"transition ease-in-out duration-300 transform absolute\"\n              leave-class=\"opacity-100 translate-y-0\"\n              leave-to-class=\"opacity-0 translate-y-8\"\n            >\n              <template v-for=\"(item, index) in items\">\n                <div\n                  :key=\"index\"\n                  v-show=\"active === index\"\n                  class=\"w-full text-center px-12 py-8 mx-4 md:mx-0\"\n                >\n                  <div class=\"inline-flex mb-3\">\n                    <!-- Twitter icon -->\n                    <svg class=\"w-8 h-8\" viewBox=\"0 0 32 32\" xmlns=\"http://www.w3.org/2000/svg\">\n                      <path d=\"M32 6.1c-1.2.5-2.4.9-3.8 1 1.4-.8 2.4-2.1 2.9-3.6-1.3.8-2.7 1.3-4.2 1.6C25.7 3.8 24 3 22.2 3c-3.6 0-6.6 2.9-6.6 6.6 0 .5.1 1 .2 1.5-5.5-.3-10.3-2.9-13.6-6.9-.6 1-.9 2.1-.9 3.3 0 2.3 1.2 4.3 2.9 5.5-1.1 0-2.1-.3-3-.8v.1c0 3.2 2.3 5.8 5.3 6.4-.6.1-1.1.2-1.7.2-.4 0-.8 0-1.2-.1.8 2.6 3.3 4.5 6.1 4.6-2.2 1.8-5.1 2.8-8.2 2.8-.5 0-1.1 0-1.6-.1 3 1.8 6.5 2.9 10.2 2.9 12.1 0 18.7-10 18.7-18.7v-.8c1.2-1 2.3-2.1 3.2-3.4z\" fill=\"#1DA1F2\" fill-rule=\"nonzero\" />\n                    </svg>\n                  </div>\n                  <blockquote class=\"text-xl md:text-2xl font-medium text-gray-800 dark:text-gray-400 mb-4\">{{item.quote}}</blockquote>\n                  <div class=\"font-medium text-lg\">\n                    <cite class=\"not-italic text-gray-800 dark:text-gray-100\">{{item.name}}</cite>\n                    <span class=\"text-gray-200 dark:text-gray-700\"> - </span>\n                    <span class=\"text-gray-500 dark:text-gray-400\">{{item.role}}</span> <a class=\"text-teal-500 hover:underline\" :href=\"item.link\">{{item.team}}</a>\n                  </div>\n                </div>\n              </template>\n\n            </transition-group>\n\n            <!-- Skewed borders -->\n            <div class=\"absolute inset-0 transform -skew-x-3 border-2 border-gray-200 dark:border-gray-800 pointer-events-none\" aria-hidden=\"true\"></div>\n\n            <!-- Arrows -->\n            <div class=\"absolute inset-0 flex items-center justify-between\">\n              <button class=\"relative z-20 w-12 h-12 p-1 box-content flex items-center justify-center group transform -translate-x-2 md:-translate-x-1/2 bg-teal-500 hover:bg-teal-400 dark:bg-gray-800 dark:hover:bg-teal-500 dark:hover:bg-opacity-25 transition duration-150 ease-in-out\" @click=\"active = active === 0 ? items.length - 1 : active - 1; stopAutorotate();\">\n                <span class=\"sr-only\">Previous</span>\n                <svg class=\"w-4 h-4 fill-current text-white dark:text-gray-400 group-hover:text-white dark:group-hover:text-teal-500 transition duration-150 ease-in-out\" viewBox=\"0 0 16 16\" xmlns=\"http://www.w3.org/2000/svg\">\n                  <path d=\"M6.7 14.7l1.4-1.4L3.8 9H16V7H3.8l4.3-4.3-1.4-1.4L0 8z\" />\n                </svg>\n              </button>\n              <button class=\"relative z-20 w-12 h-12 p-1 box-content flex items-center justify-center group transform translate-x-2 md:translate-x-1/2 bg-teal-500 hover:bg-teal-400 dark:bg-gray-800 dark:hover:bg-teal-500 dark:hover:bg-opacity-25 transition duration-150 ease-in-out\" @click=\"active = active === items.length - 1 ? 0 : active + 1; stopAutorotate();\">\n                <span class=\"sr-only\">Next</span>\n                <svg class=\"w-4 h-4 fill-current text-white dark:text-gray-400 group-hover:text-white dark:group-hover:text-teal-500 transition duration-150 ease-in-out\" viewBox=\"0 0 16 16\" xmlns=\"http://www.w3.org/2000/svg\">\n                  <path d=\"M9.3 14.7l-1.4-1.4L12.2 9H0V7h12.2L7.9 2.7l1.4-1.4L16 8z\" />\n                </svg>\n              </button>\n            </div>\n\n          </div>\n\n        </div>\n      </div>\n    </div>\n  </section>\n</template>\n\n<script>\nexport default {\n  name: 'TestimonialsCarousel',\n  data: function () {\n    return {\n      active: 0,\n      autorotate: true,\n      autorotateTiming: 7000,\n      items: [\n        {\n          quote:\n            '“ When we first met Appy, we were skeptical. We tried lots of things before and none of them worked. But, when we tested the Shape Builder it just perfect for our needs. “',\n          name: 'Alexandre Park',\n          role: 'Design Manager at',\n          team: 'Twitter',\n          link: '#0',\n        },\n        {\n          quote:\n            '“ Not only in my career but in education as well, I feel grateful that Simple pushed me to expand my horizons and strive to accomplish more.“',\n          name: 'Greg Sebastian',\n          role: 'Head of Design at',\n          team: 'Shopify',\n          link: '#0',\n        },\n        {\n          quote:\n            '“ I feel grateful that Simple pushed me to expand my horizons and strive to accomplish more. When we first met Appy, we were skeptical for no reason.“',\n          name: 'Dominik Prasad',\n          role: 'Backend Lead at',\n          team: 'Google',\n          link: '#0',\n        },\n      ],\n    }\n  },\n  methods: {\n    stopAutorotate() {\n      clearInterval(this.autorotateInterval)\n    },\n  },\n  mounted() {\n    if (this.autorotate) {\n      this.autorotateInterval = setInterval(() => {\n        this.active =\n          this.active + 1 === this.items.length ? 0 : this.active + 1\n      }, this.autorotateTiming)\n    }\n  },\n  beforeDestroy() {\n    this.stopAutorotate()\n  },\n}\n</script>"]}]}